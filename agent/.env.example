# ===== LLM 配置 =====
# OpenAI 兼容 API（支持 OpenAI / Azure / 本地模型）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# ===== Agent 配置 =====
AGENT_NAME=YHH-Agent
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true

# ===== API 服务配置 =====
API_HOST=0.0.0.0
API_PORT=8000
